# Environment
APP_ENV=development

# Supabase - Base de datos principal
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=replace_me_with_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_me_with_service_role_key_backend_only

# Redis
REDIS_URL=redis://redis:6379/0

# Storage
STORAGE_PROVIDER=supabase
SUPABASE_STORAGE_BUCKET=legal-documents

# LLM Provider (configurable: anthropic, openai, minimax)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514
# Para MiniMax usar: LLM_MODEL=MiniMax-Text-01
LLM_API_KEY=replace_me

# Embedding Provider (configurable)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=replace_me

# Security
JWT_SECRET=replace_me_with_secure_random_string
ENCRYPTION_KEY=replace_me_with_secure_random_string
